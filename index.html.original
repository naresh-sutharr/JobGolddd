            <p style="color:var(--muted); font-size:13px; margin-bottom:20px;" id="historyFormSubtitle">Apni pichhli job ki details bharein. Yeh data aapki profile ki vishwasniyata badhane mein madad karega.</p>
            <form id="jobHistoryForm">
                <input type="hidden" id="history_profile_id"> <h4 style="font-size:16px; margin-top:10px; color:var(--text-main); font-family: 'Inter', sans-serif;"><i class="fa-solid fa-user-tag"></i> Your Current Details</h4>
                <div class="row" style="margin-top:15px;">
                    <div style="flex:1"><input id="history_name" placeholder="Your Name" required></div>
                    <div style="flex:1"><input id="history_current_role" placeholder="Desired Role / New Role" required></div>
