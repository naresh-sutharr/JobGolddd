<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>JobGold — Elite Hiring Portal</title>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Playfair+Display:wght@600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  /* ================== ULTRA PREMIUM THEME (DEFAULT DARK) ================== */
  :root {
    --bg: #050505;
    --panel: rgba(20, 20, 25, 0.7);
    --text-main: #ffffff;
    --muted: #a1a1aa;
    --gold: #d4af37; /* Primary Gold */
    --gold-light: #f3d476; /* Lighter Gold */
    --gold-glow: rgba(212,175,55,0.25);
    --red: #ff4444;
    --green: #00cc66;
    --card-bg: rgba(255,255,255,0.03);
    --input-bg: rgba(0,0,0,0.3);
    --border: rgba(255,255,255,0.08);
    --shadow: 0 10px 30px rgba(0,0,0,0.8);
    --glass: blur(12px) saturate(180%);
    --scroll-track: #000;
    --scroll-thumb: #333;
    --overlay-grad-1: rgba(212, 175, 55, 0.08);
    --overlay-grad-2: rgba(0, 212, 255, 0.05);
    --grid-line: rgba(255, 255, 255, 0.03);
    --notification-badge: #ff4444; /* Added for notification badge */
  }

  /* ================== LIGHT THEME OVERRIDES ================== */
  [data-theme="light"] {
    --bg: #f4f7f6;
    --panel: rgba(255, 255, 255, 0.85);
    --text-main: #1a1a1a;
    --muted: #555555;
    --gold: #b8860b; 
    --gold-light: #e6c200;
    --gold-glow: rgba(184, 134, 11, 0.2);
    --red: #d32f2f;
    --green: #2e7d32;
    --card-bg: rgba(0,0,0,0.03);
    --input-bg: rgba(255,255,255,0.7);
    --border: rgba(0,0,0,0.1);
    --shadow: 0 10px 30px rgba(0,0,0,0.1);
    --glass: blur(15px) saturate(180%); 
    --scroll-track: #eee;
    --scroll-thumb: #ccc;
    --overlay-grad-1: rgba(184, 134, 11, 0.05);
    --overlay-grad-2: rgba(0, 150, 255, 0.05);
    --grid-line: rgba(0, 0, 0, 0.03);
    --notification-badge: #d32f2f;
  }
  
  *{box-sizing:border-box}
  html,body{height:100%;margin:0;background:var(--bg);color:var(--muted);font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased; transition: background 0.3s ease, color 0.3s ease;}
  
  /* Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--scroll-track); }
  ::-webkit-scrollbar-thumb { background: var(--scroll-thumb); border-radius: 4px; border: 1px solid var(--scroll-track); }
  ::-webkit-scrollbar-thumb:hover { background: var(--gold); }

  /* Background - Enhanced Grid */
  body::before{
    content:"";position:fixed;inset:0;
    background: 
      radial-gradient(circle at 15% 50%, var(--overlay-grad-1), transparent 25%),
      radial-gradient(circle at 85% 30%, var(--overlay-grad-2), transparent 25%);
    z-index:0;pointer-events:none;
    transition: background 0.5s ease;
  }
  body::after {
    content: ""; position: fixed; inset: 0;
    background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0; pointer-events: none; opacity: 0.3;
  }

  h1, h2, h3 { font-family: 'Playfair Display', serif; letter-spacing: 0.5px; color: var(--text-main); }

  /* --- TOAST NOTIFICATIONS (POPUP) --- */
  #toast-container { position: fixed; top: 20px; right: 20px; z-index: 10000; display: flex; flex-direction: column; gap: 10px; }
  .toast {
    min-width: 300px; padding: 16px; border-radius: 12px; background: var(--panel);
    backdrop-filter: blur(10px); border-left: 4px solid var(--gold);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2); color: var(--text-main); font-size: 14px;
    display: flex; align-items: center; gap: 12px;
    animation: slideIn 0.3s ease-out, fadeOut 0.5s ease 2.5s forwards;
    border: 1px solid var(--border);
  }
  .toast i { font-size: 18px; }
  .toast.error { border-left-color: var(--red); }
  .toast.error i { color: var(--red); }
  .toast.success { border-left-color: var(--green); }
  .toast.success i { color: var(--green); }
  
  @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes fadeOut { to { opacity: 0; transform: translateY(-20px); pointer-events: none; } }

  /* --- STYLISH NAME CLASS (Enhanced) --- */
  .user-glam-name {
    font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 800;
    /* More pronounced gold-silver gradient */
    background: linear-gradient(to right, var(--gold), var(--gold-light), var(--text-main), var(--gold-light), var(--gold));
    background-size: 400% auto; /* Larger size for better shine effect */
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    text-shadow: 0 0 20px var(--gold-glow); /* Stronger glow */
    animation: shine 6s linear infinite; /* Slower, more elegant shine */
    letter-spacing: 1.5px;
  }
  @keyframes shine { to { background-position: 400% center; } } /* Adjusted for 400% size */

  /* BUTTONS & UTILS */
  .btn {
    border:none; padding:10px 18px; border-radius:8px; cursor:pointer; font-weight:600; font-size:13px; transition:0.3s;
    background: rgba(255,255,255,0.05); color: var(--text-main); border: 1px solid var(--border);
    display: inline-flex; align-items: center; gap: 8px;
    white-space: nowrap; 
  }

  [data-theme="light"] .btn { background: rgba(0,0,0,0.05); color: var(--text-main); border-color: rgba(0,0,0,0.1); }
  [data-theme="light"] .btn:hover { background: rgba(0,0,0,0.1); }

  .btn:hover { background: rgba(255,255,255,0.15); transform: translateY(-2px); border-color: rgba(255,255,255,0.3); }
  
  .btn.cta {
    background: linear-gradient(135deg, var(--gold), var(--gold-light)); 
    color: #000 !important; border:none; font-weight:800; text-transform: uppercase; letter-spacing: 0.5px;
    box-shadow: 0 4px 15px var(--gold-glow);
    animation: pulse 3s infinite;
  }
  .btn.cta:hover { box-shadow: 0 6px 25px rgba(212,175,55,0.6); transform: translateY(-2px) scale(1.02); }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(212, 175, 55, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 175, 55, 0); }
  }

  /* --- LOGOUT BUTTON --- */
  .logout-btn {
    border: 1px solid var(--red) !important;
    color: var(--red) !important;
    background: rgba(255, 68, 68, 0.05) !important;
    padding: 8px 16px !important;
  }
  .logout-btn:hover {
    background: var(--red) !important;
    color: #fff !important;
    box-shadow: 0 0 15px rgba(255, 68, 68, 0.4);
    transform: translateY(-2px);
  }

  /* ACTION BUTTONS */
  .action-btn {
    width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center;
    border-radius: 8px; cursor: pointer; transition: all 0.3s ease;
    border: 1px solid var(--border); background: var(--card-bg);
  }
  .action-btn.edit { color: var(--gold); border-color: var(--gold); }
  .action-btn.edit:hover { background: var(--gold); color: #000; box-shadow: 0 0 15px var(--gold); transform: scale(1.1); }
  .action-btn.del { color: var(--red); border-color: var(--red); }
  .action-btn.del:hover { background: var(--red); color: #fff; box-shadow: 0 0 15px var(--red); transform: scale(1.1); }
  
  /* --- NEW: Liked/Saved Job Icon Style --- */
  .like-job-icon {
      font-size: 20px; /* Bigger Icon */
      cursor: pointer;
      color: var(--muted);
      transition: color 0.3s ease;
      padding: 5px; /* Added padding for a larger click area */
  }
  .like-job-icon:hover {
      color: var(--gold-light);
  }
  .like-job-icon.liked {
      color: var(--red) !important; 
      filter: drop-shadow(0 0 5px var(--red));
      animation: heartBeat 1s infinite alternate;
  }
  @keyframes heartBeat {
      0% { transform: scale(1.0); }
      100% { transform: scale(1.1); }
  }

  /* TOP NAVBAR FIXES (For responsiveness) */
  .topnav{
    position:sticky;top:15px;z-index:60;max-width:1200px;margin:0 auto;padding:12px 24px;
    background: var(--panel); backdrop-filter: var(--glass);
    border-radius:16px; border:1px solid var(--border);
    display:flex; align-items:center; gap:30px; /* Increased gap for spacing */
    box-shadow:var(--shadow);
    transition: background 0.3s ease;
    flex-wrap: nowrap; /* Prevent primary wrapping on wide screens */
  }
  .brand{display:flex;align-items:center;gap:12px; cursor: pointer; flex-shrink: 0;}
  /* LOGO ENHANCEMENT */
  .brandLogo{
    width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg, var(--gold), var(--gold-light));
    display:flex;align-items:center;justify-content:center;color:#000;font-size: 20px;
    box-shadow: 0 0 25px var(--gold-glow); /* Stronger glow */
    transform: rotate(-5deg); /* Slight tilt for dynamism */
  }
  .brandTitle{
    font-weight:700;color:var(--text-main); font-size:22px; 
    font-family: 'Playfair Display', serif;
    /* Added strong text shadow for premium feel */
    text-shadow: 0 0 8px var(--gold-glow);
  }
  .brand-tagline {
      font-size: 10px; color: var(--gold); letter-spacing: 1.5px; font-weight: 700;
  }
  
  .navlinks { display: flex; gap: 15px; flex-shrink: 0;} /* Increased gap for spacing */
  .navlinks button{position:relative; background:transparent;border:0;color:var(--muted);padding:8px 16px;border-radius:8px;cursor:pointer;font-weight:600; transition:.2s; font-size: 14px;}
  .navlinks button:hover { color:var(--text-main); }
  .navlinks button.active{color:var(--gold); background: var(--card-bg); border: 1px solid var(--border);}
  .spacer{flex:1}
  .top-actions { flex-shrink: 0; } 

  /* --- NEW: Notification Badge Style --- */
  #notificationBtn {
    /* Style to make it stand out */
    background: rgba(255, 255, 255, 0.08); 
    border: 1px solid var(--gold);
    color: var(--gold) !important;
  }
  #notificationBtn:hover {
    background: var(--gold-glow);
  }
  #notificationBtn i { color: var(--gold); }
  .notification-count {
      position: absolute; top: 0; right: 0;
      background: var(--notification-badge);
      color: white; font-size: 10px; font-weight: 700;
      width: 18px; height: 18px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 5px var(--notification-badge);
  }
  /* --- NEW: Notification Popup Style --- */
  #notification-popup {
      position: fixed; top: 75px; right: 20px; z-index: 70; 
      width: 320px; max-height: 400px; overflow-y: auto;
      background: var(--panel); backdrop-filter: var(--glass);
      border: 1px solid var(--border); border-radius: 12px;
      padding: 15px; box-shadow: var(--shadow);
      display: none; /* Controlled by JS */
  }
  .notification-item {
      padding: 10px 5px; border-bottom: 1px solid var(--border);
      font-size: 13px; line-height: 1.5;
      color: var(--text-main);
  }
  .notification-item:last-child { border-bottom: none; }
  .notification-item strong { color: var(--gold-light); }
  .no-notifications {
      text-align: center; color: var(--muted); padding: 20px; font-style: italic;
  }
  
  /* NEW: Notification View (Page) Style */
  .notification-card {
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 12px;
    background: var(--card-bg);
    margin-bottom: 15px;
    transition: all 0.3s;
    border-left: 4px solid var(--gold);
  }
  .notification-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }


  /* THEME TOGGLE */
  #themeToggle {
      background: transparent; border: 1px solid var(--border); color: var(--gold); width: 40px; height: 40px; 
      display: flex; align-items: center; justify-content: center; border-radius: 50%; cursor: pointer; transition: 0.3s;
  }
  #themeToggle:hover { background: var(--card-bg); transform: rotate(15deg); }

  /* LAYOUT */
  .app{position:relative;z-index:2;max-width:1200px;margin:25px auto;padding:0 20px}
  .layout{display:flex;gap:30px}
  .main{flex:1}
  
  /* SIDEBAR */
  .sidebar{
    width:260px; background:var(--panel); border-radius:16px; padding:25px;
    border:1px solid var(--border); align-self:flex-start; position: sticky; top: 95px;
    backdrop-filter: var(--glass);
  }
  .nav{margin-top:20px;display:flex;flex-direction:column;gap:8px}
  .nav button{
    background:transparent;border:0;padding:14px;text-align:left;border-radius:10px;
    color:var(--muted); cursor:pointer;font-weight:500; transition:.3s; display: flex; gap: 12px; align-items: center; font-size: 14px;
  }
  .nav button i { width: 20px; text-align: center; }
  .nav button:hover { background: var(--card-bg); color: var(--text-main); transform: translateX(5px); }
  .nav button.active{
    background:linear-gradient(90deg, var(--card-bg), transparent); 
    color:var(--gold); border-left: 3px solid var(--gold);
    text-shadow: 0 0 10px var(--gold-glow);
  }

  /* HERO & CARDS */
  .card{
    background:var(--panel); padding:24px; border-radius:18px; 
    border:1px solid var(--border); margin-bottom: 24px;
    backdrop-filter: var(--glass); box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  .hero{
    display:flex; align-items:center; justify-content:space-between; gap:20px;
    background: linear-gradient(135deg, #1e1e23, #0a0a0c); 
    border: 1px solid var(--border);
    position: relative; overflow: hidden;
  }
  [data-theme="light"] .hero { background: linear-gradient(135deg, #ffffff, #f0f0f0); }
  [data-theme="light"] .hero h1 { color: #111; }
  
  .hero::after {
    content:''; position: absolute; top:-50%; right:-50%; width: 100%; height: 200%;
    background: radial-gradient(circle, var(--gold-glow), transparent 60%);
    pointer-events: none;
  }
  
  /* ENHANCED HERO TITLE */
  .hero-title {
    font-size: 38px;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
    /* Gold Gradient Text */
    background: linear-gradient(45deg, var(--gold), var(--gold-light), var(--text-main));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 10px var(--gold-glow);
  }
  
  /* UPDATED: SearchBar spacing and Mic position fix */
  .searchBar{
    display:flex;
    gap: 15px; 
    margin-top:20px; 
    background: rgba(0,0,0,0.2); 
    padding: 8px; 
    border-radius: 12px; 
    border: 1px solid var(--border);
    flex-wrap: wrap; 
    align-items: center; /* Ensure vertical alignment */
  }
  /* NEW: Voice Search/Input Group */
  .search-group {
      display: flex;
      flex: 1;
      min-width: 200px;
      align-items: center;
      gap: 5px;
      border: 1px solid var(--border); /* Visual grouping */
      border-radius: 8px;
      background: var(--input-bg);
  }
  .search-group #voiceSearchBtn {
      order: 1; /* Move mic to the right of the input field */
      margin-left: 5px;
      margin-right: 5px;
  }
  .search-group input {
      flex: 1;
      padding-left: 10px !important; 
      background: transparent !important;
      border: none !important;
  }
  .searchBar > i {
    display: none; /* Hide magnifying glass */
  }
  
  #voiceSearchBtn {
    width: 40px; 
    height: 40px; 
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--card-bg);
    color: #00d4ff;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: 0.3s;
    flex-shrink: 0;
  }
  #voiceSearchBtn:hover {
    background: #00d4ff;
    color: #000;
    box-shadow: 0 0 15px rgba(0, 212, 255, 0.4);
    transform: scale(1.05);
  }
  #voiceSearchBtn.listening {
    background: var(--red);
    color: #fff;
    animation: pulse 1.5s infinite;
  }

  /* Select and button styling in search bar */
  .searchBar select {
    max-width: 180px; 
    flex-shrink: 1;
    border-left: 1px solid var(--border); /* Re-added separator */
  }


  .searchBar select option { background: var(--bg); color: var(--text-main); }
  
  /* JOB LIST DESIGN */
  .jobList{display:flex;flex-direction:column;gap:16px;margin-top:16px}
  .job{
    display:flex; justify-content:space-between; gap:16px; padding:24px;
    border-radius:16px; border:1px solid var(--border);
    background: var(--card-bg);
    transition: all .3s ease; position: relative; overflow: hidden;
  }
  .job:hover{ 
    transform:translateY(-5px); border-color: var(--gold); 
    box-shadow: 0 15px 40px rgba(0,0,0,0.1); 
  }
  .job h3{margin:0;color:var(--text-main);font-size:18px; font-weight: 600;}
  .meta{font-size:13px;color:var(--muted);margin-top:10px; display: flex; gap: 15px; align-items: center; flex-wrap: wrap;}
  .meta span { display: flex; align-items: center; gap: 6px; }
  .meta i { color: var(--gold); }
  
  .pill{
    background: rgba(212,175,55,0.1); color:var(--gold); padding:8px 14px; 
    border-radius:30px; font-weight:700; font-size: 13px; border:1px solid var(--gold);
    display: inline-flex; align-items: center; gap: 6px;
    white-space: nowrap;
  }
  .right { display: flex; flex-direction: column; align-items: flex-end; gap: 14px; }
  .action-row { display: flex; gap: 10px; margin-top: auto; }
  
  /* Form Rows */
  .row { display: flex; gap: 15px; }

  /* FORMS */
  input, select, textarea {
    width:100%; padding:14px; border-radius:10px; border:1px solid var(--border);
    background:var(--input-bg); color:var(--text-main); outline:none; font-family: inherit; transition: 0.3s;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--gold); background: var(--card-bg); box-shadow: 0 0 15px rgba(212,175,55,0.1); }
  
  /* File Input Custom Style */
  input[type="file"] {
      padding: 10px;
      border: 1px solid var(--border);
      background: var(--input-bg);
      cursor: pointer;
  }
  input[type="file"]::file-selector-button {
      background: var(--card-bg);
      border: 1px solid var(--border);
      padding: 6px 12px;
      border-radius: 8px;
      margin-right: 10px;
      cursor: pointer;
      color: var(--gold-light);
      transition: all 0.3s;
  }
  input[type="file"]:hover::file-selector-button {
      background: var(--gold);
      color: #000;
  }

  /* Fix for text color in select options for dark/light themes */
  select {
      color: var(--text-main) !important;
  }
  select option {
      background: var(--bg); /* Ensures background matches theme */
      color: var(--text-main); /* Ensures text color matches theme */
  }

  /* NEW: Status Flow Indicators */
  .status-flow {
      display: flex;
      gap: 5px;
      margin-top: 10px;
      font-size: 10px;
      align-items: center;
  }
  .status-step {
      display: flex;
      align-items: center;
      gap: 3px;
      font-weight: 600;
      color: var(--muted);
  }
  .status-step.active {
      color: var(--gold-light);
  }
  .status-step.completed {
      color: var(--green);
  }
  .status-step.rejected {
      color: var(--red);
  }
  .flow-arrow {
      color: var(--muted);
  }


  .footer{margin-top:40px;text-align:center;color:var(--muted);font-size:13px; border-top: 1px solid var(--border); padding-top: 20px;}
  .footer-icons { margin-top: 10px; display: flex; justify-content: center; gap: 20px; font-size: 18px; }
  /* UPDATED: Footer Icons */
  .footer-icons a i { 
    cursor: pointer; 
    transition: 0.3s; 
    color: var(--muted); 
  }
  .footer-icons a:hover i { 
    color: var(--gold); 
    transform: scale(1.2); 
  }

  /* AUTH MODAL */
  .modal{display:none;position:fixed;inset:0;align-items:center;justify-content:center;z-index:999;background:rgba(0,0,0,0.85); backdrop-filter: blur(8px); padding: 10px;}
  
  /* UPDATED: Height set to 505px */
  .auth-wrapper {
        position: relative; width: 100%; max-width: 800px; height: 505px;
        border: 2px solid #00d4ff; box-shadow: 0 0 30px rgba(0, 212, 255, 0.4);
        overflow: hidden; background: #1a1a2e; border-radius: 16px;
    }
    .auth-wrapper .credentials-panel { position: absolute; top: 0; width: 50%; height: 100%; display: flex; justify-content: center; flex-direction: column; z-index: 20; }
    .credentials-panel.signin { left: 0; padding: 0 40px; }
    .credentials-panel.signin .slide-element { transform: translateX(0%); transition: .7s; opacity: 1; }
    .credentials-panel.signin .slide-element:nth-child(1) { transition-delay: 0.8s; }
    .credentials-panel.signin .slide-element:nth-child(2) { transition-delay: 0.9s; }
    .credentials-panel.signin .slide-element:nth-child(3) { transition-delay: 1.0s; }
    .credentials-panel.signin .slide-element:nth-child(4) { transition-delay: 1.1s; }
    .credentials-panel.signin .slide-element:nth-child(5) { transition-delay: 1.2s; }
    .auth-wrapper.toggled .credentials-panel.signin .slide-element { transform: translateX(-120%); opacity: 0; }
    .auth-wrapper.toggled .credentials-panel.signin .slide-element:nth-child(1) { transition-delay: 0s; }

    .credentials-panel.signup { right: 0; padding: 0 60px; }
    .credentials-panel.signup .slide-element { transform: translateX(120%); transition: .7s ease; opacity: 0; filter: blur(10px); }
    .credentials-panel.signup .slide-element:nth-child(1) { transition-delay: 0s; }
    .auth-wrapper.toggled .credentials-panel.signup .slide-element { transform: translateX(0%); opacity: 1; filter: blur(0px); }
    .auth-wrapper.toggled .credentials-panel.signup .slide-element:nth-child(1) { transition-delay: 1.7s; }
    .auth-wrapper.toggled .credentials-panel.signup .slide-element:nth-child(2) { transition-delay: 1.8s; }

    .credentials-panel h2 { font-size: 32px; text-align: center; color: white; margin-bottom: 20px;}
    .credentials-panel .field-wrapper { position: relative; width: 100%; height: 50px; margin-top: 25px; }
    .field-wrapper input, .field-wrapper select { width: 100%; height: 100%; background: transparent; border: none; outline: none; font-size: 16px; color: #fff; font-weight: 600; border-bottom: 2px solid #fff; padding-right: 23px; transition: .5s; border-radius: 0; padding-left: 0;}
    .field-wrapper input:-webkit-autofill { -webkit-box-shadow: 0 0 0 30px #1a1a2e inset !important; -webkit-text-fill-color: white !important; }
    .field-wrapper input:focus, .field-wrapper input:valid { border-bottom: 2px solid #00d4ff; }
    .field-wrapper label { position: absolute; top: 50%; left: 0; transform: translateY(-50%); font-size: 16px; color: #fff; transition: .5s; pointer-events: none;}
    /* Fix for register select label position */
    .field-wrapper input:focus~label, .field-wrapper input:valid~label, .field-wrapper select:valid~label, .field-wrapper select:focus~label { top: -5px; color: #00d4ff; font-size: 12px; }
    
    /* UPDATED: Password Toggle Icon Style (Stylish Button) */
    .field-wrapper i { position: absolute; top: 50%; right: 0; font-size: 18px; transform: translateY(-50%); color: #fff; transition: 0.3s; }
    
    /* STYLISH TOGGLE BUTTON CSS (IMPROVED COLOR CONTRAST) */
    .field-wrapper i.pass-toggle { 
        cursor: pointer; 
        z-index: 100; 
        pointer-events: all;
        background: rgba(255, 255, 255, 0.1); /* Glass background */
        padding: 5px;
        border-radius: 50%; /* Circle shape */
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid rgba(255,255,255,0.1);
        right: 0px !important; /* Force position */
        color: #fff !important; /* Default white for better contrast */
    }
    .field-wrapper i.pass-toggle:hover { 
        background: var(--gold); 
        color: #000 !important; 
        box-shadow: 0 0 12px var(--gold-glow);
        transform: translateY(-50%) scale(1.1); /* Slightly enlarge */
        border-color: var(--gold);
    }
    /* Fixed: Ensure the icon color remains white/gold on focus, not blue */
    .field-wrapper input:focus~i, .field-wrapper input:valid~i { color: var(--gold-light); }
    
    /* UPDATED: Register Role Select Colors (Visibility Fix) */
    .field-wrapper select {
        color: var(--text-main) !important; /* Keep select text theme color */
    }
    /* FIX FOR SELECT OPTION VISIBILITY IN DARK THEME */
    .field-wrapper select option { 
        background: var(--bg); /* Ensures background matches theme */
        color: var(--text-main); /* Ensures text color matches theme */
        font-weight: 500;
    }

    .submit-button { position: relative; width: 100%; height: 45px; background: transparent; border-radius: 40px; cursor: pointer; font-size: 16px; font-weight: 600; border: 2px solid #00d4ff; overflow: hidden; z-index: 1; color: white; margin-top: 20px;}
    .submit-button::before { content: ""; position: absolute; height: 300%; width: 100%; background: linear-gradient(#1a1a2e, #00d4ff, #1a1a2e, #00d4ff); top: -100%; left: 0; z-index: -1; transition: .5s; }
    .submit-button:hover:before { top: 0; }
    .switch-link { font-size: 14px; text-align: center; margin: 20px 0 10px; color: white; }
    .switch-link a { text-decoration: none; color: #00d4ff; font-weight: 600; }

    .welcome-section { position: absolute; top: 0; height: 100%; width: 50%; display: flex; justify-content: center; flex-direction: column; color:white; z-index: 10; }
    .welcome-section.signin { right: 0; text-align: right; padding: 0 40px 60px 150px; }
    .welcome-section.signin .slide-element { transform: translateX(0); transition: .7s ease; opacity: 1; filter: blur(0px); }
    .welcome-section.signin .slide-element:nth-child(1) { transition-delay: 2.0s; }
    .auth-wrapper.toggled .welcome-section.signin .slide-element { transform: translateX(120%); opacity: 0; }
    .auth-wrapper.toggled .welcome-section.signin .slide-element:nth-child(1) { transition-delay: 0s; }

    .welcome-section.signup { left: 0; text-align: left; padding: 0 150px 60px 38px; pointer-events: none; }
    .welcome-section.signup .slide-element { transform: translateX(-120%); transition: .7s ease; opacity: 0; }
    .auth-wrapper.toggled .welcome-section.signup .slide-element { transform: translateX(0%); opacity: 1; }
    .auth-wrapper.toggled .welcome-section.signup .slide-element:nth-child(1) { transition-delay: 1.7s; }

    .welcome-section h2 { text-transform: uppercase; font-size: 36px; line-height: 1.3; }
    .auth-wrapper .background-shape { position: absolute; right: 0; top: -5px; height: 600px; width: 850px; background: linear-gradient(45deg, #1a1a2e, #00d4ff); transform: rotate(10deg) skewY(40deg); transform-origin: bottom right; transition: 1.5s ease; transition-delay: 1.6s; z-index: 0; }
    .auth-wrapper.toggled .background-shape { transform: rotate(0deg) skewY(0deg); transition-delay: .5s; }
    .auth-wrapper .secondary-shape { position: absolute; left: 250px; top: 100%; height: 700px; width: 850px; background: #1a1a2e; border-top: 3px solid #00d4ff; transform: rotate(0deg) skewY(0deg); transform-origin: bottom left; transition: 1.5s ease; transition-delay: .5s; z-index: 0; }
    .auth-wrapper.toggled .secondary-shape { transform: rotate(-11deg) skewY(-41deg); transition-delay: 1.2s; }
    .modal-close-btn { position: absolute; top: 15px; right: 15px; background: #00d4ff; width: 32px; height: 32px; border-radius: 50%; border: none; cursor: pointer; z-index: 100; font-weight: bold; color: #000; display:flex; align-items:center; justify-content:center;}

    /* --- PROFILE CARD STYLES --- */
    .profile-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        padding: 20px;
        border-radius: 12px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        margin-bottom: 15px;
        transition: border-color 0.3s ease;
    }
    .profile-card:hover {
        border-color: var(--gold);
    }
    
    /* Naresh Suthar Premium Card Style */
    .profile-card.premium {
        border: 2px solid var(--gold-light);
        /* UPDATED: Light theme compatibility for creator card background */
        background: linear-gradient(135deg, var(--card-bg), rgba(212,175,55,0.05));
        box-shadow: 0 0 25px var(--gold-glow);
    }
    .profile-card.premium .profile-photo {
        border: 3px solid var(--gold-light);
        box-shadow: 0 0 15px var(--gold-glow);
    }
    .profile-card.premium .role {
        font-size: 15px;
        color: var(--gold-light);
        font-weight: 700;
        text-shadow: 0 0 5px rgba(212,175,55,0.3);
    }
    
    .profile-card.pending {
        border: 2px solid var(--muted);
        opacity: 0.8;
    }
    .profile-card.pending .profile-photo {
        filter: grayscale(80%);
    }
    .profile-card.pending .hire-status {
        color: var(--muted);
    }


    .profile-card-left {
        display: flex;
        align-items: flex-start; /* Changed to flex-start to align top */
        gap: 20px;
    }
    .profile-photo {
        flex-shrink: 0;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid var(--gold-light);
        box-shadow: 0 0 10px var(--gold-glow);
    }
    .profile-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .profile-info h4 {
        margin: 0;
        font-size: 18px;
        color: var(--text-main);
    }
    .profile-info .role {
        font-size: 14px;
        color: var(--gold);
        font-weight: 600;
        margin-top: 4px;
    }
    .profile-info .prev-company {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }
    .profile-info .experience-text {
        font-size: 13px;
        margin-top: 10px;
        color: var(--muted);
        white-space: pre-wrap; /* Allows line breaks in the description */
    }
    .profile-card-right {
        text-align: right;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 10px;
    }
    .hire-btn {
        background: var(--green);
        color: #000 !important;
        border: none;
        font-weight: 700;
        padding: 8px 16px;
        transition: 0.3s;
    }
    .hire-btn:hover {
        background: var(--green);
        box-shadow: 0 0 15px rgba(0, 204, 102, 0.5);
    }
    .verify-btn {
        background: #00d4ff;
        color: #000 !important;
        border: none;
        font-weight: 700;
        padding: 8px 16px;
        transition: 0.3s;
    }
    .verify-btn:hover {
        background: #00a4d4;
        box-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
    }
    .profile-del-btn {
        border: 1px solid var(--red) !important;
        color: var(--red) !important;
        background: rgba(255, 68, 68, 0.05) !important;
        padding: 8px 16px !important;
        font-weight: 600;
    }
    .profile-del-btn:hover {
        background: var(--red) !important;
        color: #fff !important;
        box-shadow: 0 0 15px rgba(255, 68, 68, 0.4);
    }

    .profile-edit-btn {
        border: 1px solid var(--gold) !important;
        color: var(--gold) !important;
        background: rgba(212, 175, 55, 0.05) !important;
        padding: 8px 16px !important;
        font-weight: 600;
    }
    .profile-edit-btn:hover {
        background: var(--gold) !important;
        color: #000 !important;
        box-shadow: 0 0 15px var(--gold-glow);
    }
    .hire-status {
        font-size: 12px;
        color: var(--muted);
        margin-top: 8px;
    }

    /* --- ENHANCED DASHBOARD STATS (ADDED GLOW) --- */
    .stat-card {
        display: flex; align-items: center; gap: 25px; 
        border-left: 4px solid var(--gold); margin: 0;
        transition: all 0.3s ease;
        /* Added box shadow/glow based on card type */
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    /* Gold Card Glow */
    .stat-card:first-child {
        box-shadow: 0 0 20px var(--gold-glow);
        border-left-color: var(--gold-light);
    }
    /* Application Card Glow */
    .stat-card:last-child {
        box-shadow: 0 0 20px rgba(0, 212, 255, 0.15);
        border-left-color: #00d4ff;
    }
    
    /* Premium About Me Card Styles */
    .about-me-card {
        border: 2px solid var(--gold-light);
        /* UPDATED: Light theme compatibility for creator card background */
        background: var(--panel); 
        box-shadow: 0 0 35px var(--gold-glow);
        padding: 30px;
    }
    /* Light Theme specific fix for About Me Card */
    [data-theme="light"] .about-me-card {
        border: 2px solid var(--gold);
        background: rgba(255, 255, 255, 0.95);
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
    }
    .about-me-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        border-bottom: 1px solid var(--border); padding-bottom: 20px; margin-bottom: 20px;
    }
    .about-me-info {
        display: flex; gap: 25px;
    }
    .about-me-photo-container {
        width: 120px; height: 120px; border-radius: 50%; overflow: hidden;
        border: 4px solid var(--gold-light); box-shadow: 0 0 15px var(--gold-glow);
        flex-shrink: 0;
    }
    .about-me-photo {
        width: 100%; height: 100%; object-fit: cover;
    }
    .about-me-details {
        display: flex; flex-direction: column; justify-content: center;
    }
    .detail-item {
        display: flex; align-items: center; gap: 10px; margin-bottom: 8px;
        font-size: 14px;
    }
    .detail-item i { color: var(--gold-light); }
    .about-me-experience h4 {
        margin-top: 30px;
        color: var(--gold);
        font-size: 18px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 10px;
    }
    .about-me-experience p {
        white-space: pre-wrap;
        line-height: 1.7;
        color: var(--muted);
        margin-top: 15px;
    }
    .about-me-title {
        font-family: 'Playfair Display', serif; 
        font-size: 26px; 
        font-weight: 800;
        background: linear-gradient(to right, var(--gold), var(--gold-light));
        -webkit-background-clip: text; 
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 10px var(--gold-glow);
        margin: 0;
    }
    
    /* MAP CONTAINER STYLE (Moved to its own view) */
    #map-container {
        height: 400px; 
        width: 100%; 
        border-radius: 12px; 
        border: 2px solid var(--border); 
        overflow: hidden;
        box-shadow: var(--shadow);
        background: #2a2a2a; /* Placeholder background for map area */
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold-light);
        font-size: 18px;
        position: relative;
    }
    /* 3D Map Simulation Style */
    #map-iframe {
        width: 100%;
        height: 100%;
        border: none;
        filter: grayscale(50%) contrast(1.1);
    }


  @media (max-width: 768px) {
        /* Adjusted min-height for mobile to match new wrapper height */
        .auth-wrapper { height: auto; min-height: 505px; flex-direction: column; }
        .auth-wrapper .credentials-panel, .welcome-section { width: 100%; position: relative; }
        .credentials-panel.signin, .credentials-panel.signup { padding: 40px 30px; left: 0; right: 0; }
        .credentials-panel.signin { display: flex; animation: fadeInUp 0.6s ease forwards; }
        .credentials-panel.signup { display: none; }
        .auth-wrapper.toggled .credentials-panel.signin { display: none; }
        .auth-wrapper.toggled .credentials-panel.signup { display: flex; animation: fadeInUp 0.6s ease forwards; }
        .credentials-panel.signin .slide-element, .credentials-panel.signup .slide-element { transform: translateY(0); opacity: 1; filter: blur(0); animation: slideInUp 0.5s ease forwards; }
        .welcome-section { display: none; }
        .auth-wrapper .background-shape, .auth-wrapper .secondary-shape { display: none; }
        
        /* Notification Popup Fix */
        #notification-popup { left: 50%; right: auto; transform: translateX(-50%); width: 90%; }
  }

  /* ========================================= */
  /* ============ MOBILE FIXES =============== */
  /* ========================================= */

  @media (max-width: 900px) {
    /* WRAP LAYOUT: Stack Sidebar & Main */
    .layout { flex-direction: column; }
    .sidebar { width: 100%; position: relative; top: 0; margin-bottom: 20px; }
    
    /* WRAP TOPBAR (Enable wrap only below 900px) */
    .topnav { flex-wrap: wrap; height: auto; justify-content: center; padding: 10px; }
    .brand { width: 100%; justify-content: center; margin-bottom: 10px; }
    .spacer { display: none; }
    .navlinks { width: 100%; display: flex; justify-content: center; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
    .top-actions { width: 100%; justify-content: center; margin-top: 10px;}
    #guestNav, #userNav { justify-content: center; flex-wrap: wrap; }
    
    /* FIX FORMS */
    .row { flex-direction: column; gap: 10px; }
    .searchBar { flex-direction: column; }
    .searchBar select { max-width: 100% !important; border-left: none; border-top: 1px solid rgba(255,255,255,0.1); }
    
    /* DASHBOARD STATS */
    #view-dashboard > div { grid-template-columns: 1fr !important; }

    /* MOBILE ABOUT ME FIX */
    .about-me-card { padding: 20px; }
    .about-me-header { flex-direction: column; align-items: center; text-align: center;}
    .about-me-info { flex-direction: column; align-items: center; text-align: center; gap: 15px;}
    .about-me-title { font-size: 22px; }
    
    /* Search bar wrap fix for mic button */
    .searchBar { gap: 10px; }
    .search-group { width: 100%; }
    .searchBar > select, .searchBar > button { min-width: 48%; }
    .searchBar #searchBtn { min-width: 100%; }
  }

  @media (max-width: 600px) {
    /* WRAP HERO */
    .hero { flex-direction: column; text-align: center; padding: 30px 20px; }
    .heroRight { display: none; } /* Hide big icon on small phones */
    
    /* WRAP JOB CARDS */
    .job { flex-direction: column; }
    .right { flex-direction: row; width: 100%; justify-content: space-between; align-items: center; margin-top: 15px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 10px; }
    .action-row { margin-top: 0; }
  }
</style>
</head>
<body>

<div id="toast-container"></div>

<div class="topnav">
  <div class="brand" id="navLogo">
    <div class="brandLogo"><i class="fa-solid fa-crown"></i></div>
    <div>
      <div class="brandTitle">JobGold</div>
      <div class="brand-tagline">✨ ELITE HIRING PARTNER</div>
    </div>
  </div>

  <div class="navlinks" id="topLinks">
    <button class="active" data-view="dashboard"><i class="fa-solid fa-gauge-high"></i> Dashboard</button>
    <button data-view="jobs"><i class="fa-solid fa-briefcase"></i> Browse Jobs</button>
    <button data-view="notifications" id="notificationBtn" data-role="jobseeker,admin" style="display:none;">
        <i class="fa-solid fa-bell"></i> Notifications
        <span id="notificationCount" class="notification-count" style="display:none;">0</span>
    </button>
  </div>
  
  <div id="notification-popup">
      <h4 style="margin: 0 0 10px 0; color: var(--gold-light); font-size: 16px;">Hire Notifications</h4>
      <div id="notificationList"></div>
  </div>

  <div class="spacer"></div>

  <div class="top-actions" style="display:flex; gap:15px; align-items:center;">
      
      <button id="themeToggle" title="Toggle Light/Dark Mode">
          <i class="fa-solid fa-sun" id="themeIcon"></i>
      </button>

      <div id="guestNav" style="display:flex; gap:10px;">
        <button class="btn" id="openLogin"><i class="fa-solid fa-arrow-right-to-bracket"></i> Login</button>
        <button class="btn" id="openRegister">Register</button>
        <button class="btn cta" id="ctaApply" data-role="employer,admin" style="display:none;"><i class="fa-solid fa-plus"></i> Post Job</button>
      </div>
      <div id="userNav" style="display:none; gap:15px; align-items:center;">
        <div style="text-align:right; line-height:1.2;">
            <div id="userGreeting" class="user-glam-name"></div>
            <div id="userRoleDisplay" style="font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:1px;"></div>
        </div>
        <button class="btn logout-btn" id="doLogout">
            <i class="fa-solid fa-power-off"></i> <span>LOGOUT</span>
        </button>
      </div>
  </div>
</div>

<div class="app">
  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <nav class="nav">
        <button class="active" data-view="dashboard"><i class="fa-solid fa-gauge-high" style="color:var(--gold)"></i> Dashboard</button>
        <button data-view="add" data-role="employer,admin" style="display:none;"><i class="fa-solid fa-circle-plus" style="color:#4caf50"></i> Post New Job</button>
        <button data-view="jobs"><i class="fa-solid fa-list-check" style="color:#2196f3"></i> All Active Jobs</button>
        
        <button data-view="employer-apps" data-role="employer,admin" style="display:none;"><i class="fa-solid fa-handshake-angle" style="color:#9c27b0"></i> Applications Received</button>
        <button data-view="jobseeker-apps" data-role="jobseeker,admin" style="display:none;"><i class="fa-solid fa-file-invoice" style="color:#2196f3"></i> My Job Applications</button>

        <button data-view="profiles"><i class="fa-solid fa-user-gear" style="color:var(--gold)"></i> Candidate Profiles</button>
        <button data-view="submit-history" data-role="jobseeker,admin" style="display:none;"><i class="fa-solid fa-clock-rotate-left" style="color:#64b5f6"></i> Share Job History</button>
        <button data-view="saved-jobs" data-role="jobseeker,admin" style="display:none;"><i class="fa-solid fa-heart" style="color:var(--red);"></i> Saved Jobs</button>
        <button data-view="map"><i class="fa-solid fa-map-location-dot" style="color:#00d4ff;"></i> Jobs Near Me (Map)</button>
        <button data-view="about-me"><i class="fa-solid fa-user-secret" style="color:#f3d476"></i> About Me / Admin</button>
      </nav>
      
      <div style="margin-top:auto; padding-top:20px; border-top:1px solid var(--border); text-align:center;">
         <div class="tiny" style="color:var(--muted); font-size:12px;"><i class="fa-solid fa-shield-halved"></i> Secure Connection</div>
         <div style="font-size:11px; margin-top:5px; color:var(--muted)">Status: <span id="statusIndicator" style="color:var(--gold)">...</span></div>
      </div>
    </aside>

    <main class="main">
      <section class="hero card">
        <div class="heroLeft" style="flex:2">
          <h1 class="hero-title">Find elite talent.</h1>
          <h1 class="hero-title"><span style="color:var(--gold)">Hire in 24 Hours.</span></h1>
          <p class="tiny" style="color:var(--muted); margin-top:10px; font-size:14px;">The world's most premium local hiring portal. Fast, Secure & Free.</p>

          <div class="searchBar">
            <div class="search-group">
                <input id="searchInput" placeholder="Search by title, skill or city...">
                <div id="voiceSearchBtn" title="Search using your voice (Simulated)">
                    <i class="fa-solid fa-microphone"></i>
                </div>
            </div>
            <select id="searchCategory" style="border-left:1px solid var(--border);"></select>
            <select id="searchSalaryRange" style="border-left:1px solid var(--border);">
                <option value="">Salary Range</option>
                <option value="0-10000">0 - 10K</option>
                <option value="10000-20000">10K - 20K</option>
                <option value="20000-30000">20K - 30K</option>
                <option value="30000-50000">30K - 50K</option>
                <option value="50000-999999">50K+</option>
            </select>
            <button class="btn cta" id="searchBtn" style="border-radius: 8px;">Find Elite Match</button>
          </div>
        </div>

        <div class="heroRight" style="flex:1; display:flex; justify-content:center; align-items:center;">
             <i class="fa-solid fa-trophy" style="font-size:100px; background: -webkit-linear-gradient(#d4af37, #f3d476); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 20px rgba(212,175,55,0.4)); animation: float 4s ease-in-out infinite;"></i>
        </div>
        <style> @keyframes float { 0% {transform: translateY(0px);} 50% {transform: translateY(-15px);} 100% {transform: translateY(0px);} } </style>
      </section>

      <div id="view-dashboard" class="view">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:30px;">
            <div class="card stat-card">
                <div class="stat-icon"><i class="fa-solid fa-briefcase-alt"></i></div>
                <div>
                    <div class="stat-value" id="statJobs">0</div>
                    <div class="stat-label">Active Job Posts</div>
                </div>
            </div>
            <div class="card stat-card">
                <div class="stat-icon" style="background:var(--card-bg); color:#00d4ff; box-shadow: 0 0 15px rgba(0, 212, 255, 0.2);"><i class="fa-solid fa-file-invoice"></i></div>
                <div>
                    <div class="stat-value" style="background: linear-gradient(90deg, var(--text-main), #00d4ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;" id="statApps">0</div>
                    <div class="stat-label" id="statAppsLabel">Total Applications</div>
                </div>
            </div>
        </div>
        
        <h3 style="margin-top:30px; margin-bottom:15px; display:flex; align-items:center; gap:10px;">
            <i class="fa-solid fa-gem" style="color:var(--gold); font-size: 20px;"></i> 
            <span style="font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 800; background: linear-gradient(to right, var(--gold), var(--gold-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Elite Recent Listings
            </span>
        </h3>

        <div id="recentJobs" class="jobList"></div>
      </div>
      
      <div id="view-map" class="view" style="display:none">
          <h3 style="color:var(--text-main); margin-bottom:15px;"><i class="fa-solid fa-map-location-dot" style="color:#00d4ff;"></i> Jobs Near Me (Map View)</h3>
          <p style="color:var(--muted); font-size:13px; margin-bottom:20px;">View available job locations on the map below (Simulated 3D Look).</p>
          <div id="map-container" class="card">
             <iframe id="map-iframe" src="" title="Simulated 3D Map of Jobs Near Me" allowfullscreen></iframe>
          </div>
      </div>

      <div id="view-about-me" class="view" style="display:none">
          <div id="aboutMeCard" class="card about-me-card">
            </div>
          
          <div id="creatorEditFormContainer" class="card" style="display:none; margin-top: 30px;">
            <h3 id="creatorFormTitle"><i class="fa-solid fa-pen-to-square" style="color:var(--gold)"></i> Edit Creator Profile</h3>
            <p style="color:var(--muted); font-size:13px; margin-bottom:20px;">Update your master profile details here.</p>
            <form id="creatorProfileForm">
                <input type="hidden" id="creator_profile_id" value="p1"> 
                <h4 style="font-size:16px; margin-top:10px; color:var(--text-main); font-family: 'Inter', sans-serif;"><i class="fa-solid fa-user-tag"></i> Profile Details</h4>
                <div class="row" style="margin-top:15px;">
                    <div style="flex:1"><input id="creator_name" placeholder="Your Name" required></div>
                    <div style="flex:1"><input id="creator_current_role" placeholder="Current Role / Title" required></div>
                </div>
                
                <h4 style="font-size:16px; margin-top:30px; color:var(--text-main); font-family: 'Inter', sans-serif;"><i class="fa-solid fa-camera"></i> Profile Photo</h4>
                <div style="margin-top:15px;">
                    <input type="file" id="creator_photo" accept="image/*" title="Upload new professional photo">
                </div>

                <h4 style="font-size:16px; margin-top:30px; color:var(--text-main); font-family: 'Inter', sans-serif;"><i class="fa-solid fa-feather-pointed"></i> About Me / Experience</h4>
                <div style="margin-top:15px;">
                    <textarea id="creator_description" placeholder="Describe your experience and goals..." style="height:120px;" required></textarea>
                </div>

                <div class="actionsRow" style="margin-top:25px; display:flex; justify-content:flex-end; gap:15px;">
                    <button type="button" class="btn" id="cancelCreatorEdit">Cancel</button>
                    <button type="submit" class="btn cta" id="updateCreatorBtn">Update Profile <i class="fa-solid fa-cloud-arrow-up"></i></button>
                </div>
            </form>
          </div>
          <div id="adminSettingsCard" class="card" style="margin-top: 30px;">
