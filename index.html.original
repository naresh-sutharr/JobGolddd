            <p style="color:var(--muted); font-size:13px; margin-bottom:20px;">Manage local admin access and data operations.</p>
            <div class="heroActions" style="display:flex; gap:15px; margin-top: 20px; flex-wrap: wrap;">
                <button class="btn" id="exportBtn"><i class="fa-solid fa-cloud-arrow-down"></i> Backup Data</button>
                <button class="btn" id="importBtn"><i class="fa-solid fa-cloud-arrow-up"></i> Restore Data</button>
            </div>

            <div class="row" style="margin-top:30px; border-top:1px solid var(--border); padding-top:20px; flex-wrap: wrap;">
                <h4 style="width:100%; font-size:16px; margin-top:0px; color:var(--text-main); font-family: 'Inter', sans-serif;"><i class="fa-solid fa-user-plus"></i> Create New Admin</h4>
