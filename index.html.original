                <h4 style="font-size:16px; margin-top:30px; color:var(--text-main); font-family: 'Inter', sans-serif;"><i class="fa-solid fa-building-user"></i> Previous Job Details</h4>
                <div class="row" style="margin-top:15px;">
                    <div style="flex:1"><input id="history_prev_company" placeholder="Previous Company/Shop Name" required></div>
                    <div style="flex:1"><input id="history_prev_role" placeholder="Your Role at Previous Job (e.g., Salesman)" required></div>
