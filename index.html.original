                <p class="tiny" style="color:var(--red)">Danger Zone (Admin Only)</p>
                <button class="btn" style="border-color:var(--red); color:var(--red); background:rgba(255,0,0,0.05)" id="clearAll"><i class="fa-solid fa-trash"></i> Delete All Data</button>
            </div>
          </div>
      </div>
      <div id="view-add" class="view" style="display:none">
        <div class="card">
            <h3><i class="fa-solid fa-pen-nib" style="color:var(--gold)"></i> Post a New Elite Job</h3>
            <p style="color:var(--muted); font-size:13px; margin-bottom:20px;">Fill in the details to reach thousands of candidates.</p>
            <form id="jobForm">
              <div class="row">
                <div style="flex:2"><input id="f_title" placeholder="Job Title (e.g. Senior Chef)" required></div>
                <div style="flex:1"><input id="f_company" placeholder="Company Name"></div>
              </div>
              <div class="row" style="margin-top:15px;">
                <select id="f_category" style="flex:1" required onchange="toggleOtherCategory()"></select>
                <input id="f_salary" type="number" placeholder="Monthly Salary (₹)" required style="flex:1">
