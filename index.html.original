              </div>
              
              <div id="f_other_category_container" style="margin-top:15px; display:none;">
                  <input id="f_other_category_input" placeholder="Enter custom category name (e.g., HVAC Technician)">
              </div>

              <div style="margin-top:15px;">
                <textarea id="f_description" placeholder="Describe the role, requirements and timings..." style="height:120px;"></textarea>
              </div>
              <div class="actionsRow" style="margin-top:25px; display:flex; justify-content:flex-end; gap:15px;">
                <button type="button" class="btn" id="clearForm">Reset Form</button>
                <button type="submit" class="btn cta" id="saveJobBtn">Publish Elite Job <i class="fa-solid fa-arrow-right"></i></button>
